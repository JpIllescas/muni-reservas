# ====== Base de datos ======
# Cadena de conexión completa de PostgreSQL (Neon/AWS en la nube, o Postgres local)
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db
# SSL de la BD: true para Neon/AWS, false para Postgres local
DB_SSL=false

# ====== Entorno ======
# development | production | test  (controla synchronize y logging de TypeORM)
NODE_ENV=development

# ====== JWT ======
# Secreto largo y aleatorio. Genéralo con:  openssl rand -hex 48
JWT_SECRET=
# Duración del token: "7d", "24h" o un número en SEGUNDOS (ej. 604800 = 7 días).
JWT_EXPIRES_IN=7d

# ====== Correo (SMTP) ======
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=tu_app_password_de_gmail

# ====== Archivos / subida de boletas ======
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=5

# ====== Frontend (para CORS) ======
FRONTEND_URL=http://localhost:4200

# ====== Servidor ======
PORT=3000
